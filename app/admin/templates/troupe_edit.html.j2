{% extends "base_admin.html.j2"%}

{% block title %}
    La Compagnie
{% endblock %}

{% block content%}
    <div class="container mt-6">
        <h1 class="is-size-1 mb-6">Dashboard</h1>

        <nav class="breadcrumb mb-6" aria-label="breadcrumbs">
            <ul>
                <li><a href="{{ url_for('admin.dashboard') }}">Dashboard</a></li>
                <li class="is-active"><a href="{{ url_for('admin.troupe') }}" aria-current="page">La Compagnie</a></li>

            </ul>
        </nav>

        <nav class="panel">
            <p class="panel-heading">Liste des membres de la troupe</p>
            {% for m in members %}
                <a href="{{ url_for('admin.member', id=m.id) }}" class="panel-block">{{ m.first_name }} {{ m.last_name }} - {{ m.display_order }}</a>
            {% endfor %}
        </nav>
    </div>
{% endblock %}