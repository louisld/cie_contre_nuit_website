{% extends "base_admin.html.j2"%}

{% block title %}
    Membre
{% endblock %}

{% block content%}
    <div class="container mt-6">
        <h1 class="is-size-1 mb-6">Dashboard</h1>

        <nav class="breadcrumb mb-6" aria-label="breadcrumbs">
            <ul>
                <li><a href="{{ url_for('admin.dashboard') }}">Dashboard</a></li>
                <li><a href="{{ url_for('admin.troupe') }}">La Compagnie</a></li>
                <li class="is-active"><a href="{{ url_for('admin.member', id=member.id) }}" aria-current="page"></a>{{ member.first_name }} {{ member.last_name }}</li>
            </ul>
        </nav>

        <h2 class="is-size-2">Édition du membre {{ member.first_name }} {{ member.last_name }}</h2>
        <div class="columns">
            <div class="column">
                <figure class="image is-1by1 member-picture">
                    <img src="{{ url_for('static', filename='main/troupe/uploads/' + member.id|string + '_cover.jpg') }}" onerror="this.src='{{ url_for('static', filename='main/troupe/cover.png') }}'" alt="Pas d'image de profil">
                </figure>
                <img class="is-size-2-img mt-6" src="{{ url_for('static', filename='main/troupe/uploads/' + member.id|string + '_name.png') }}">
            </div>
            <div class="column">
                 <form action="{{ url_for('admin.member', id=member.id) }}" method="post" enctype="multipart/form-data">
                    {{ member_form.hidden_tag() }}
                    <div class="field">
                        <label class="label">Id</label>
                        <div class="control">
                            <input type="text" class="input" disabled value="{{ member.id }}">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Prénom</label>
                        <div class="control">
                            {{ member_form.first_name(class="input", value=member.first_name) }}
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Nom de famille</label>
                        <div class="control">
                            {{ member_form.last_name(class="input", value=member.last_name) }}
                        </div>
                    </div>
                     <div class="field">
                        <label class="label">Rôle</label>
                        <div class="control">
                            {{ member_form.role(class="input", value=member.role) }}
                        </div>
                    </div>
                     <div class="field">
                        <label class="label">Ordre d'affichage</label>
                        <div class="control">
                            {{ member_form.display_order(class="input", value=member.display_order) }}
                        </div>
                        <p class="help">Le plus grand en premier.</p>
                    </div>
                    <div id="member-edit-file" class="file has-name is-fullwidth">
                        <label class="file-label">
                            {{ member_form.cover_img(class="file-input") }}
                            <span class="file-cta">
                                <span class="file-icon">
                                    <i class="fas fa-upload"></i>
                                </span>
                                <span class="file-label">Photo de profil</span>
                            </span>
                            <span class="file-name"></span>
                        </label>
                    </div>
                    <div id="member-edit-file-2" class="file has-name is-fullwidth">
                        <label class="file-label">
                            {{ member_form.name_img(class="file-input") }}
                            <span class="file-cta">
                                <span class="file-icon">
                                    <i class="fas fa-upload"></i>
                                </span>
                                <span class="file-label">Image de nom</span>
                            </span>
                            <span class="file-name"></span>
                        </label>
                    </div>
                    <div class="field">
                        <div class="control">
                            <button class="button is-success">Modifier</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        const fileInput = document.querySelector("#member-edit-file input[type=file]");
        fileInput.onchange = () => {
            if (fileInput.files.length > 0) {
            const fileName = document.querySelector("#member-edit-file .file-name");
            fileName.textContent = fileInput.files[0].name;
            }
        };
        const fileInput2 = document.querySelector("#member-edit-file-2 input[type=file]");
        fileInput2.onchange = () => {
            if (fileInput2.files.length > 0) {
            const fileName2 = document.querySelector("#member-edit-file-2 .file-name");
            fileName2.textContent = fileInput2.files[0].name;
            }
        };
    </script>
{% endblock %}