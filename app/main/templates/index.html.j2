{% set header_title_class = "header-title-index" %}
{% extends "base.html.j2"%}

{% block title %}
    Compagnie à Contre-Nuit
{% endblock %}

{% block meta %}
    <meta name="description" content="La Compagnie à Contre-Nuit est née d'une passion pour le théâtre d'étudiants qui ont voulu prolonger l'aventure au-delà de leurs études. Elle met en lumière des sujets variés et souvent complexes, qui nous tiennent à cœur. Nos créations cherchent avant tout à susciter l'émotion et le débat, en ouvrant un espace où l'intime rejoint l'universel.">
    <meta name="author" content="Anna Raffault et Louis Grandvaux">
    <link rel="canonical" content="{{ config.SERVER_NAME }}">
{% endblock %}

{% block header_title %}
    <img src="{{ url_for('static', filename='main/index/banner_a_contre_nuit.png') }}" alt="À Contre-Nuit">
{% endblock %}

{% block content %}
    <div class="container mt-6 mb-6">
        <h2 class="mb-6 mx-4"><img src="{{ url_for('static', filename='main/index/actualites.png') }}" alt="Actualités" class="is-size-2-img"></h2>
        <div class="fixed-grid has-2-cols has-1-cols-mobile">
            <div class="grid is-gap-6">
                {% for p in projects %}
                <div class="card card-project-index">
                    <div class="card-image">
                        <figure class="image">
                            <a href="{{ url_for('main.play', short_title=p.short_title) }}"><img src="{{ url_for('static', filename='main/projects/uploads/'+p.id|string+'_banner.png') }}" onerror="this.src='{{ url_for('static', filename='img/cover.png') }}'" alt="Banière de {{ p.full_title }}"></a>
                        </figure>
                    </div>
                    <div class="card-content">
                        <div class="content">
                            {# <h3><img class="is-size-2-img" src="{{ url_for('static', filename='main/projects/uploads/'+p.id|string+'_title.png') }}" alt="{{ p.short_title }}"></h3> #}
                            <p class="card-description">{{ p.short_description | truncate(500) }}</p>
                            <p class="has-text-right"><a class="link" href="{{ url_for('main.play', short_title=p.short_title) }}">En savoir plus</a></p>
                        </div>
                    </div>
                </div>
                <div class="px-4">
                    {% for place in p.representation_places %}
                        <h2 class="mt-4 is-dark-3 is-inline-block"><img src="{{ url_for('static', filename='main/projects/uploads/representation_places/' + place.id|string + '_title.png') }}" alt="{{ place.name }}" class="is-size-2-img"></h2>

                        {% for date in place.representation_dates %}
                            <div class="is-flex is-flex-direction-column">
                                <div class="bb-black-4 mt-5">
                                    <img src="{{ url_for('static', filename='main/projects/uploads/representation_dates/' + date.id|string + '_datetime.png') }}" alt="{{ date.date }}" class="is-size-2-img">
                                </div>
                            </div>
                        {% endfor %}
                        {% if place.ticket_link %}
                            <div class="mt-4 is-flex is-flex is-justify-content-flex-end">
                                <a href="{{ place.ticket_link }}"><img src="{{ url_for('static', filename='main/index/ticket_here.png') }}" alt="Billet ici" class="is-size-1-5-img"></a>
                            </div>
                        {% endif%}
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}